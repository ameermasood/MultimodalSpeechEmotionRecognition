# Base Voxtral model. Use either a Hugging Face model ID or a local model path.
BASE_MODEL_ID=mistralai/Voxtral-Mini-3B-2507

# Fine-tuned adapter directory. This should contain adapter_config.json and
# adapter_model.safetensors or adapter_model.bin.
ADAPTER_PATH=checkpoints/final_adapter_dora

# Runtime options for local inference/demo.
LOAD_IN_4BIT=false
DEVICE=auto

# Optional demo settings.
MAX_NEW_TOKENS=8
DO_SAMPLE=false
TEMPERATURE=0.2
TOP_P=0.95
